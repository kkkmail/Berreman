Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"delta", " ", "=", " ", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"bump", "[", 
    RowBox[{"x_", ",", "d_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"HeavisideTheta", "[", 
       RowBox[{"x", "+", "d"}], "]"}], "-", 
      RowBox[{"HeavisideTheta", "[", 
       RowBox[{"x", "-", "d"}], "]"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"2", "*", " ", "d"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gaussianBump", "[", 
    RowBox[{"x_", ",", "d_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"x", "^", "2"}]}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", 
        RowBox[{"d", "^", "2"}]}], ")"}]}], "]"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", "*", "Pi"}], "]"}], "*", " ", "d"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"bump", "[", 
    RowBox[{"x", ",", "d"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"d", " ", ">", " ", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"gaussianBump", "[", 
    RowBox[{"x", ",", "d"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"d", " ", ">", " ", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", "2"}], "*", 
    RowBox[{"bump", "[", 
     RowBox[{"x", ",", "d"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"d", " ", ">", " ", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "^", "2"}], "*", 
     RowBox[{"gaussianBump", "[", 
      RowBox[{"x", ",", "d"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"d", " ", ">", " ", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"bump", "[", 
      RowBox[{"x", ",", "delta"}], "]"}], ",", 
     RowBox[{"gaussianBump", "[", 
      RowBox[{"x", ",", "delta"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", " ", 
   RowBox[{"Frame", "->", "True"}], ",", " ", 
   RowBox[{"GridLines", "->", "Automatic"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"e", "[", 
    RowBox[{"k_", ",", "z_", ",", "d_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"I", "*", "k", "*", "z"}], "]"}], "*", 
    RowBox[{"bump", "[", 
     RowBox[{"z", ",", "d"}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "I"}], "*", "k1", "*", "x"}], "]"}], "*", 
    RowBox[{"gaussianBump", "[", 
     RowBox[{"x", ",", "d"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"d", " ", ">", " ", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], "*", "k1", "*", "x"}], "]"}], "*", 
     RowBox[{"bump", "[", 
      RowBox[{"x", ",", "d"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"d", " ", ">", " ", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "k", "*", "x"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "k1", "*", "x"}], "]"}], "*", 
      RowBox[{"bump", "[", 
