Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"https", ":"}], "//", 
    RowBox[{
     RowBox[{
      RowBox[{"en", ".", "wikipedia", ".", "org"}], "/", "wiki"}], "/", 
     "Gaussian_beam"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"k", "=", 
    RowBox[{"2", "*", "Pi", "*", 
     RowBox[{"n", "/", "\[Lambda]"}]}]}], "\[IndentingNewLine]", 
   RowBox[{"zR", " ", "=", " ", 
    RowBox[{"Pi", " ", "*", " ", 
     RowBox[{"w0", "^", "2"}], " ", "*", " ", 
     RowBox[{"n", " ", "/", " ", "\[Lambda]"}]}]}], " ", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"R", "[", "z_", "]"}], ":=", 
     RowBox[{"z", "*", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"zR", "/", "z"}], ")"}], "^", "2"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"w", "[", "z_", "]"}], ":=", 
     RowBox[{"w0", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"z", "/", "zR"}], ")"}], "^", "2"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Psi]", "[", "z_", "]"}], ":=", 
     RowBox[{"ArcTan", "[", 
      RowBox[{"z", "/", "zR"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"e", "[", 
      RowBox[{"r_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"w0", "/", 
        RowBox[{"w", "[", "z", "]"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"r", "^", "2"}]}], "/", 
        RowBox[{
         RowBox[{"w", "[", "z", "]"}], "^", "2"}]}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "*", "z"}], "+", 
          RowBox[{"(", 
           RowBox[{"k", "*", 
            RowBox[{
             RowBox[{"r", "^", "2"}], "/", 
             RowBox[{"(", 
              RowBox[{"2", "*", 
               RowBox[{"R", "[", "z", "]"}]}], ")"}]}]}], ")"}], "-", 
          RowBox[{"\[Psi]", "[", "z", "]"}]}], ")"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ea", "[", 
     RowBox[{"r_", ",", "z_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"e", "[", 
      RowBox[{"r", ",", "z"}], "]"}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", "*", "k", "*", "z"}], "]"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"e1", "[", 
      RowBox[{"r_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"w0", "/", "wz"}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"r", "^", "2"}]}], "/", 
        RowBox[{"wz", "^", "2"}]}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "*", "z"}], "+", 
          RowBox[{"(", 
           RowBox[{"k", "*", 
            RowBox[{
             RowBox[{"r", "^", "2"}], "/", 
             RowBox[{"(", 
              RowBox[{"2", "*", "Rz"}], ")"}]}]}], ")"}], "-", "\[Psi]z"}], 
         ")"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<w[z]^2/R[z]\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"w", "[", "z", "]"}], "^", "2"}], "/", 
     RowBox[{"R", "[", "z", "]"}]}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<e[r,z]\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"e", "[", 
    RowBox[{"r", ",", "z"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"e", "[", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
